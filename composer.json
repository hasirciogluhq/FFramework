{
  "name": "hasirciogluhq/fframework",
  "description": "Lightweight PHP framework: HTTP routing, views, config, and PDO-friendly database helpers.",
  "type": "library",
  "keywords": [
    "fframework",
    "framework",
    "php",
    "routing",
    "mvc",
    "http"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Hasircioglu",
      "email": "mhasirciogli@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-pdo": "*",
    "phpmailer/phpmailer": "^6.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1"
  },
  "autoload": {
    "psr-4": {
      "FFramework\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\": "test-app/app/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
